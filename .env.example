# Copy this file to .env and adjust for your environment.
# DEBUG=True  -> Flask's dev server (auto-reload, debugger). Use for local dev only.
# DEBUG=False -> waitress (production WSGI server). Use when deploying.
DEBUG=True
HOST=127.0.0.1
PORT=5000

DEFAULT_EXCHANGE=NASDAQ
COLLECT_DATA_TIMEOUT_SECONDS=15
CACHE_TTL_SECONDS=900
MIN_DATA_POINTS=30
MAX_DATA_POINTS=500
